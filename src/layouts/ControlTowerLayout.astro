---
import { getCollection } from 'astro:content';
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	image?: string;
	pubDate?: Date;
}

const { title, description, image = '/images/olivia-wedding-hero.png', pubDate } = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<!-- Primary Meta Tags -->
		<title>{title} | Chicago AI Web Factory</title>
		<meta name="title" content={`${title} | Chicago AI Web Factory`} />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={pubDate ? "article" : "website"} />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={`${title} | Chicago AI Web Factory`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={`${title} | Chicago AI Web Factory`} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url)} />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

		<!-- Custom Modern Light Design Theme -->
		<style is:global>
			:root {
				--bg-white: #FFFFFF;
				--bg-light: #F8FAFC;
				--text-main: #0F172A;
				--text-muted: #475569;
				--accent-blue: #0052FF;
				--accent-blue-hover: #0041CC;
				--accent-blue-light: #EBF2FF;
				--border-color: #F1F5F9;
				--shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.02), 0 2px 4px 0 rgba(0, 0, 0, 0.02);
				--shadow-md: 0 4px 20px -2px rgba(0, 82, 255, 0.05), 0 4px 6px -1px rgba(0, 0, 0, 0.02);
				--shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.02), 0 4px 6px -4px rgba(0, 0, 0, 0.02);
				--radius-md: 16px;
				--radius-lg: 24px;
				--font-sans: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
			}

			* {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			body {
				font-family: var(--font-sans);
				background-color: var(--bg-white);
				color: var(--text-main);
				line-height: 1.6;
				overflow-x: hidden;
			}

			a {
				color: inherit;
				text-decoration: none;
				transition: all 0.2s ease;
			}

			/* Container utilities */
			.container {
				max-width: 1152px; /* max-w-6xl */
				margin: 0 auto;
				padding: 0 24px;
			}

			/* AdSense responsive slot style */
			.adsense-placeholder {
				background: var(--bg-light);
				border: 1px dashed var(--border-color);
				border-radius: var(--radius-md);
				padding: 20px;
				text-align: center;
				font-size: 0.8rem;
				color: var(--text-muted);
				margin: 2rem 0;
			}
		</style>
	</head>
	<body>
		<header style="border-bottom: 1px solid var(--border-color); position: sticky; top: 0; background: rgba(255, 255, 255, 0.75); backdrop-filter: blur(16px); z-index: 100;">
			<div class="container" style="display: flex; justify-content: space-between; align-items: center; height: 72px;">
				<a href="/" style="display: flex; align-items: center; gap: 8px; font-weight: 800; font-size: 1.2rem; color: var(--text-main);">
					<span style="background: var(--accent-blue); color: white; padding: 4px 10px; border-radius: 12px; font-size: 1rem; font-weight: 800;">LAB</span>
					LAB: AI Experiment Lab
				</a>
				<nav style="display: flex; gap: 24px; font-weight: 600; font-size: 0.9rem;">
					<a href="/" style="color: var(--text-muted);" onmouseover="this.style.color='var(--accent-blue)'" onmouseout="this.style.color='var(--text-muted)'">홈</a>
					<a href="/blog" style="color: var(--text-muted);" onmouseover="this.style.color='var(--accent-blue)'" onmouseout="this.style.color='var(--text-muted)'">빌드 저널</a>
					<a href="/operator" style="color: var(--accent-blue);" onmouseover="this.style.color='var(--accent-blue-hover)'" onmouseout="this.style.color='var(--accent-blue)'">오퍼레이터</a>
				</nav>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer style="background: var(--bg-light); border-top: 1px solid var(--border-color); padding: 60px 0 40px 0; margin-top: 80px;">
			<div class="container">
				<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 40px; margin-bottom: 40px;">
					<div>
						<h3 style="font-weight: 800; color: var(--accent-blue); margin-bottom: 16px;">AI Experiment Lab & Journal</h3>
						<p style="color: var(--text-muted); font-size: 0.95rem;">A기반 비즈니스 모델 구축과 오픈 소스 형태의 개발 여정을 기록하는 블로그 저널 공간입니다.</p>
					</div>
					<div>
						<h4 style="font-weight: 700; margin-bottom: 16px;">바로가기</h4>
						<ul style="list-style: none; display: flex; flex-direction: column; gap: 10px; font-size: 0.95rem; color: var(--text-muted);">
							<li><a href="/" onmouseover="this.style.color='var(--accent-blue)'" onmouseout="this.style.color='var(--text-muted)'">홈</a></li>
							<li><a href="/blog" onmouseover="this.style.color='var(--accent-blue)'" onmouseout="this.style.color='var(--text-muted)'">빌드 저널</a></li>
							<li><a href="/operator" onmouseover="this.style.color='var(--accent-blue)'" onmouseout="this.style.color='var(--text-muted)'">오퍼레이터</a></li>
						</ul>
					</div>
					<div>
						<h4 style="font-weight: 700; margin-bottom: 16px;">Journal Info</h4>
						<p style="color: var(--text-muted); font-size: 0.95rem;">Build in Public & AI Development Journey</p>
					</div>
				</div>
				<hr style="border: 0; border-top: 1px solid var(--border-color); margin-bottom: 24px;" />
				<div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; font-size: 0.9rem; color: var(--text-muted);">
					<p>&copy; {new Date().getFullYear()} AI Experiment Lab & Journal. All rights reserved.</p>
					<p>Designed for AI Journey</p>
				</div>
			</div>
		</footer>
	</body>
</html>
