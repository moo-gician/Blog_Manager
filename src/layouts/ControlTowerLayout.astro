---
import { getCollection } from 'astro:content';
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	image?: string;
	pubDate?: Date;
}

const { title, description, image = '/images/olivia-wedding-hero.png', pubDate } = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<!-- Primary Meta Tags -->
		<title>{title} | DALO</title>
		<meta name="title" content={`${title} | DALO (To the Moon with AI)`} />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={pubDate ? "article" : "website"} />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={`${title} | DALO`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={`${title} | DALO`} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url)} />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

		<!-- Custom Modern Light Design Theme -->
		<style is:global>
			:root {
				--bg-white: #FFFFFF;
				--bg-light: #F8FAFC;
				--text-main: #0F172A;
				--text-muted: #475569;
				--accent-blue: #0052FF;
				--accent-blue-hover: #0041CC;
				--accent-blue-light: #EBF2FF;
				--border-color: #F1F5F9;
				--shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.02), 0 2px 4px 0 rgba(0, 0, 0, 0.02);
				--shadow-md: 0 4px 20px -2px rgba(0, 82, 255, 0.05), 0 4px 6px -1px rgba(0, 0, 0, 0.02);
				--shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.02), 0 4px 6px -4px rgba(0, 0, 0, 0.02);
				--radius-md: 16px;
				--radius-lg: 24px;
				--font-sans: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
			}

			* {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			body {
				font-family: var(--font-sans);
				background-color: var(--bg-light);
				color: var(--text-main);
				line-height: 1.6;
				overflow-x: hidden;
			}

			a {
				color: inherit;
				text-decoration: none;
				transition: all 0.2s ease;
			}

			/* Container utilities */
			.container {
				max-width: 1100px; /* max-w-[1100px] */
				margin: 0 auto;
				padding: 0 24px;
			}
		</style>
	</head>
	<body class="bg-slate-50 text-slate-900 font-sans leading-relaxed">
		<!-- Floating Centered Glassmorphism Header -->
		<div style="position: sticky; top: 0; z-index: 100; padding: 16px 0; display: flex; justify-content: center;">
			<header style="background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(20px); border: 1px solid rgba(15, 23, 42, 0.05); border-radius: 99px; box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.04); width: calc(100% - 40px); max-width: 1100px; z-index: 100;">
				<div style="display: flex; justify-content: space-between; align-items: center; height: 60px; padding: 0 24px;">
					<a href="/" style="display: flex; align-items: center; gap: 8px; font-weight: 800; font-size: 1.15rem; color: var(--text-main); letter-spacing: -0.03em;">
						<img src="/images/dalo-logo.svg" alt="DALO Logo" style="width: 24px; height: 24px;" />
						<span>DALO</span>
					</a>
					
					<div style="display: flex; align-items: center; gap: 20px;">
						<nav style="display: flex; gap: 20px; font-weight: 600; font-size: 0.85rem;">
							<a href="/" style="color: var(--text-muted);" onmouseover="this.style.color='var(--accent-blue)'" onmouseout="this.style.color='var(--text-muted)'">홈</a>
							<a href="/blog" style="color: var(--text-muted);" onmouseover="this.style.color='var(--accent-blue)'" onmouseout="this.style.color='var(--text-muted)'">빌드 저널</a>
							<a href="/about" style="color: var(--text-muted);" onmouseover="this.style.color='var(--accent-blue)'" onmouseout="this.style.color='var(--text-muted)'">소개 (About)</a>
							<a href="/operator" style="color: var(--accent-blue);" onmouseover="this.style.color='var(--accent-blue-hover)'" onmouseout="this.style.color='var(--accent-blue)'">오퍼레이터</a>
						</nav>

						<!-- Keyword Search Trigger -->
						<button id="btn-search-trigger" style="background: none; border: none; cursor: pointer; color: var(--text-muted); display: flex; align-items: center; padding: 4px;" class="hover:text-blue-600 transition">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
						</button>
					</div>
				</div>
			</header>
		</div>

		<!-- Search Overlay Modal -->
		<div id="search-modal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-[1000] hidden items-start justify-center pt-24 transition-opacity duration-300">
			<div class="bg-white border border-slate-100 rounded-[24px] max-w-xl w-full mx-4 p-6 shadow-xl space-y-4">
				<div class="flex justify-between items-center border-b border-slate-100 pb-3">
					<h3 class="font-extrabold text-sm text-slate-800">🔍 실시간 키워드 검색</h3>
					<button id="btn-search-close" class="text-xs font-bold text-slate-400 hover:text-slate-800">닫기 (Esc)</button>
				</div>
				<input type="text" id="search-input" placeholder="검색어를 입력해 주세요..." class="w-full text-sm border border-slate-200 rounded-xl px-4 py-3 outline-none focus:border-blue-600 bg-slate-50" />
				<div id="search-results-container" class="max-h-[300px] overflow-y-auto space-y-2.5">
					<p class="text-xs text-slate-400 text-center py-6">검색어를 입력하면 매칭되는 저널이 노출됩니다.</p>
				</div>
			</div>
		</div>

		<main>
			<slot />
		</main>

		<!-- Footer -->
		<footer style="background: var(--bg-light); border-top: 1px solid var(--border-color); padding: 60px 0 40px 0; margin-top: 80px;">
			<div class="container">
				<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 40px; margin-bottom: 40px;">
					<div>
						<div style="display: flex; align-items: center; gap: 8px; margin-bottom: 16px;">
							<img src="/images/dalo-logo.svg" alt="DALO Logo" style="width: 24px; height: 24px;" />
							<span style="font-weight: 800; font-size: 1.15rem;">DALO</span>
						</div>
						<p style="color: var(--text-muted); font-size: 0.85rem; line-height: 1.6;">"AI로 한계를 넘어, 달로 가자 (To the Moon with AI)."</p>
					</div>
					<div>
						<h4 style="font-weight: 700; margin-bottom: 16px; font-size: 0.9rem;">바로가기</h4>
						<ul style="list-style: none; display: flex; flex-direction: column; gap: 10px; font-size: 0.85rem; color: var(--text-muted);">
							<li><a href="/" onmouseover="this.style.color='var(--accent-blue)'" onmouseout="this.style.color='var(--text-muted)'">홈</a></li>
							<li><a href="/blog" onmouseover="this.style.color='var(--accent-blue)'" onmouseout="this.style.color='var(--text-muted)'">빌드 저널</a></li>
							<li><a href="/about" onmouseover="this.style.color='var(--accent-blue)'" onmouseout="this.style.color='var(--text-muted)'">소개 (About)</a></li>
							<li><a href="/operator" onmouseover="this.style.color='var(--accent-blue)'" onmouseout="this.style.color='var(--text-muted)'">오퍼레이터</a></li>
						</ul>
					</div>
					<div>
						<h4 style="font-weight: 700; margin-bottom: 16px; font-size: 0.9rem;">소개</h4>
						<p style="color: var(--text-muted); font-size: 0.85rem; line-height: 1.6;">AI 비즈니스 모델 빌드 인 퍼블릭 저널.</p>
					</div>
				</div>
				<hr style="border: 0; border-top: 1px solid var(--border-color); margin-bottom: 24px;" />
				<div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; font-size: 0.8rem; color: var(--text-muted);">
					<p>&copy; {new Date().getFullYear()} DALO (To the Moon with AI). All rights reserved.</p>
					<p>Designed in Josh Comeau Style</p>
				</div>
			</div>
		</footer>

		<!-- Search Client-Side Script -->
		<script>
			const searchTrigger = document.getElementById('btn-search-trigger');
			const searchModal = document.getElementById('search-modal');
			const searchClose = document.getElementById('btn-search-close');
			const searchInput = document.getElementById('search-input') as HTMLInputElement;
			const searchResults = document.getElementById('search-results-container');

			let searchData: any[] = [];

			// Fetch indices once
			async function initSearch() {
				try {
					const res = await fetch('/search.json');
					searchData = await res.json();
				} catch (err) {
					console.error("Failed to load search data:", err);
				}
			}

			function toggleModal(open: boolean) {
				if (open) {
					searchModal?.classList.remove('hidden');
					searchModal?.classList.add('flex');
					searchInput.focus();
					if (searchData.length === 0) initSearch();
				} else {
					searchModal?.classList.add('hidden');
					searchModal?.classList.remove('flex');
					searchInput.value = '';
					searchResults!.innerHTML = `<p class="text-xs text-slate-400 text-center py-6">검색어를 입력하면 매칭되는 저널이 노출됩니다.</p>`;
				}
			}

			searchTrigger?.addEventListener('click', () => toggleModal(true));
			searchClose?.addEventListener('click', () => toggleModal(false));
			searchModal?.addEventListener('click', (e) => {
				if (e.target === searchModal) toggleModal(false);
			});

			window.addEventListener('keydown', (e) => {
				if (e.key === 'Escape') toggleModal(false);
			});

			searchInput?.addEventListener('input', () => {
				const query = searchInput.value.trim().toLowerCase();
				if (!query) {
					searchResults!.innerHTML = `<p class="text-xs text-slate-400 text-center py-6">검색어를 입력하면 매칭되는 저널이 노출됩니다.</p>`;
					return;
				}

				const matches = searchData.filter(item => 
					item.title.toLowerCase().includes(query) || 
					item.description.toLowerCase().includes(query) ||
					(item.tags && item.tags.some((t: string) => t.toLowerCase().includes(query)))
				);

				if (matches.length === 0) {
					searchResults!.innerHTML = `<p class="text-xs text-slate-400 text-center py-6">검색 결과가 없습니다.</p>`;
					return;
				}

				searchResults!.innerHTML = matches.map(item => `
					<a href="/blog/${item.id}" class="block bg-slate-50 hover:bg-blue-50 border border-slate-100 rounded-xl p-3.5 transition">
						<span class="bg-blue-100 text-blue-800 text-[9px] font-bold px-1.5 py-0.5 rounded">${item.category}</span>
						<h4 class="text-xs font-bold text-slate-800 mt-1.5 leading-snug">${item.title}</h4>
						<p class="text-[10px] text-slate-400 mt-1 line-clamp-1">${item.description}</p>
					</a>
				`).join('');
			});
		</script>
	</body>
</html>
