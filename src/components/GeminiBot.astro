---
---

<!-- Floating Chat Button -->
<button id="chatbot-toggle" style="position: fixed; bottom: 32px; right: 32px; width: 64px; height: 64px; border-radius: 99px; background: var(--accent-blue); color: white; border: none; box-shadow: var(--shadow-lg); cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 1000; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); border: 2px solid white;">
	<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="chat-icon"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
	<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="close-icon" style="display: none;"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
</button>

<!-- Chat Window -->
<div id="chatbot-window" style="position: fixed; bottom: 110px; right: 32px; width: 380px; max-width: calc(100vw - 64px); height: 500px; border-radius: var(--radius-lg); background: var(--bg-white); border: 1px solid var(--border-color); box-shadow: var(--shadow-lg); display: flex; flex-direction: column; z-index: 1000; opacity: 0; transform: translateY(20px) scale(0.95); pointer-events: none; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);">
	<!-- Header -->
	<div style="background: var(--accent-blue); color: white; padding: 20px; border-top-left-radius: 15px; border-top-right-radius: 15px; display: flex; align-items: center; gap: 12px;">
		<div style="width: 10px; height: 10px; background: #4ADE80; border-radius: 99px;"></div>
		<div>
			<h4 style="font-weight: 700; font-size: 0.95rem; line-height: 1.2;">시카고 AI 상담 비서 (Gemini)</h4>
			<p style="font-size: 0.75rem; opacity: 0.8;">Chicago AI-Local Web Factory</p>
		</div>
	</div>

	<!-- Messages -->
	<div id="chat-messages" style="flex-grow: 1; padding: 20px; overflow-y: auto; display: flex; flex-direction: column; gap: 12px; font-size: 0.9rem;">
		<!-- Welcome Message -->
		<div style="background: var(--bg-light); padding: 12px 16px; border-radius: 12px; max-width: 85%; align-self: flex-start; line-height: 1.5; color: var(--text-main);">
			안녕하세요! 시카고 AI 웹 공장의 컨설턴트 봇입니다. 3일 만에 구축되는 초고속 로컬 웹 제작 및 AI 마케팅 시스템에 대해 궁금한 점을 물어보세요!
		</div>
		
		<!-- Chips -->
		<div id="suggestion-chips" style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px;">
			<button class="chip" data-question="3일 구축 프로세스가 어떻게 되나요?">⏱️ 3일 구축 과정</button>
			<button class="chip" data-question="Astro 프레임워크의 장점이 무엇인가요?">⚡ Astro의 장점</button>
			<button class="chip" data-question="AI 오퍼레이터는 무엇을 자동화하나요?">🤖 AI 오퍼레이터 기능</button>
		</div>
	</div>

	<!-- Input Area -->
	<div style="padding: 16px; border-top: 1px solid var(--border-color); display: flex; gap: 8px;">
		<input type="text" id="chat-input" placeholder="메시지를 입력하세요..." style="flex-grow: 1; border: 1px solid var(--border-color); padding: 10px 16px; border-radius: 99px; font-family: inherit; font-size: 0.9rem; outline: none; transition: border-color 0.2s;" />
		<button id="chat-send" style="background: var(--accent-blue); border: none; color: white; width: 40px; height: 40px; border-radius: 99px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background 0.2s;">
			<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
		</button>
	</div>
</div>

<style>
	.chip {
		background: var(--accent-blue-light);
		color: var(--accent-blue);
		border: 1px solid rgba(0, 82, 255, 0.15);
		padding: 6px 12px;
		border-radius: 99px;
		font-size: 0.75rem;
		font-weight: 600;
		cursor: pointer;
		transition: all 0.2s ease;
	}
	.chip:hover {
		background: var(--accent-blue);
		color: white;
	}
	#chatbot-toggle:hover {
		transform: scale(1.08);
		background: var(--accent-blue-hover);
	}
	#chat-input:focus {
		border-color: var(--accent-blue);
	}
	#chat-send:hover {
		background: var(--accent-blue-hover);
	}
</style>

<script>
	const toggleBtn = document.getElementById('chatbot-toggle');
	const chatWindow = document.getElementById('chatbot-window');
	const messagesContainer = document.getElementById('chat-messages');
	const chatInput = document.getElementById('chat-input') as HTMLInputElement;
	const sendBtn = document.getElementById('chat-send');
	const chips = document.querySelectorAll('.chip');

	let isOpen = false;

	// Toggle Chat Window
	toggleBtn?.addEventListener('click', () => {
		isOpen = !isOpen;
		if (isOpen) {
			chatWindow!.style.opacity = '1';
			chatWindow!.style.transform = 'translateY(0) scale(1)';
			chatWindow!.style.pointerEvents = 'auto';
			(toggleBtn.querySelector('.chat-icon') as HTMLElement).style.display = 'none';
			(toggleBtn.querySelector('.close-icon') as HTMLElement).style.display = 'block';
		} else {
			chatWindow!.style.opacity = '0';
			chatWindow!.style.transform = 'translateY(20px) scale(0.95)';
			chatWindow!.style.pointerEvents = 'none';
			(toggleBtn.querySelector('.chat-icon') as HTMLElement).style.display = 'block';
			(toggleBtn.querySelector('.close-icon') as HTMLElement).style.display = 'none';
		}
	});

	// AI Response Data mapping
	const qaDatabase: Record<string, string> = {
		"3일 구축 프로세스가 어떻게 되나요?": `시카고 AI 웹 공장의 3일 프로세스는 다음과 같습니다:<br/><br/>
		<strong>1일차 (기획 및 뼈대):</strong> 3대 핵심 파일(Plan, Context, Todo)을 수립하고 사이트 뼈대를 설정합니다.<br/>
		<strong>2일차 (개발 및 최적화):</strong> Astro.build를 통해 웹 디자인 시스템을 로딩 최적화 상태로 빌드하고 갤러리 및 로컬 매핑을 완료합니다.<br/>
		<strong>3일차 (AI 결합 및 배포):</strong> Gemini 마케팅 봇을 탑재하고 Firebase Hosting으로 초고속 호스팅 배포를 완료합니다.`,
		
		"astro 프레임워크의 장점이 무엇인가요?": `Astro는 <strong>Zero-JS (초경량 아키텍처)</strong>를 기본으로 동작합니다.<br/><br/>
		1. <strong>압도적인 스피드:</strong> 필요하지 않은 경우 클라이언트에 자바스크립트를 전혀 전송하지 않아 구글 라이트하우스 100점을 쉽게 달성합니다.<br/>
		2. <strong>최상의 SEO:</strong> 서버사이드 혹은 정적 빌드로 완벽한 HTML을 만들어 구글 로컬 검색 로봇에 가장 친화적입니다.<br/>
		3. <strong>로컬 마케팅 최적화:</strong> 웹 로딩 속도가 1초 빨라질 때마다 전환율이 최대 20% 상승합니다.`,
		
		"ai 오퍼레이터는 무엇을 자동화하나요?": `AI 오퍼레이터는 소상공인의 실시간 작업로그(.md)를 돈이 되는 마케팅 콘텐츠로 복사합니다.<br/><br/>
		1. <strong>블로그 스토리텔링:</strong> Plan/Context/Todo의 원시 로그를 감성적인 클라이언트 사례 마케팅 포스트로 변환.<br/>
		2. <strong>SNS 증폭기:</strong> 링크드인 및 인스타그램에 최적화된 마케팅 문구 및 해시태그 스니펫 자동 생성.`
	};

	function appendMessage(text: string, isUser: boolean) {
		const msg = document.createElement('div');
		msg.style.padding = '12px 16px';
		msg.style.borderRadius = '12px';
		msg.style.maxWidth = '85%';
		msg.style.lineHeight = '1.5';
		
		if (isUser) {
			msg.style.background = 'var(--accent-blue)';
			msg.style.color = 'white';
			msg.style.alignSelf = 'flex-end';
			msg.textContent = text;
		} else {
			msg.style.background = 'var(--bg-light)';
			msg.style.color = 'var(--text-main)';
			msg.style.alignSelf = 'flex-start';
			msg.innerHTML = text;
		}
		
		messagesContainer?.insertBefore(msg, document.getElementById('suggestion-chips'));
		messagesContainer!.scrollTop = messagesContainer!.scrollHeight;
	}

	function handleQuestion(question: string) {
		appendMessage(question, true);
		
		// Typings simulation
		const typing = document.createElement('div');
		typing.style.padding = '8px 12px';
		typing.style.alignSelf = 'flex-start';
		typing.style.color = 'var(--text-muted)';
		typing.style.fontSize = '0.8rem';
		typing.textContent = "답변을 입력하고 있습니다...";
		messagesContainer?.insertBefore(typing, document.getElementById('suggestion-chips'));
		
		setTimeout(() => {
			typing.remove();
			const answer = qaDatabase[question] || `죄송합니다. "${question}"에 대한 최적의 답변을 찾지 못했습니다. 구체적인 견적이나 맞춤형 솔루션 상담은 '3일 구축 문의'를 이용해 주시기 바랍니다.`;
			appendMessage(answer, false);
		}, 1000);
	}

	chips.forEach(chip => {
		chip.addEventListener('click', (e) => {
			const target = e.currentTarget as HTMLButtonElement;
			const question = target.getAttribute('data-question');
			if (question) {
				handleQuestion(question);
			}
		});
	});

	sendBtn?.addEventListener('click', () => {
		const query = chatInput.value.trim();
		if (query) {
			handleQuestion(query);
			chatInput.value = '';
		}
	});

	chatInput?.addEventListener('keypress', (e) => {
		if (e.key === 'Enter') {
			const query = chatInput.value.trim();
			if (query) {
				handleQuestion(query);
				chatInput.value = '';
			}
		}
	});
</script>
