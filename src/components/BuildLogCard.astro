---
interface Props {
	title: string;
	description: string;
	pubDate: Date;
	slug: string;
	status: string;
	tags?: string[];
	heroImage?: string;
}

const { title, description, pubDate, slug, status, tags = [], heroImage } = Astro.props;
---

<div class="card" style="background: var(--bg-light); border: 1px solid var(--border-color); border-radius: var(--radius-lg); overflow: hidden; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); display: flex; flex-direction: column; height: 100%; box-shadow: var(--shadow-sm);">
	{heroImage && (
		<div style="position: relative; height: 180px; overflow: hidden; background: #eee;">
			<img src={heroImage} alt={title} style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;" class="card-img" />
			<span style="position: absolute; top: 12px; right: 12px; background: white; color: var(--text-main); padding: 4px 10px; border-radius: 99px; font-size: 0.65rem; font-weight: 700; border: 1px solid var(--border-color);">
				{status}
			</span>
		</div>
	)}
	<div style="padding: 24px; flex-grow: 1; display: flex; flex-direction: column; gap: 12px;">
		<div style="display: flex; gap: 8px; flex-wrap: wrap;">
			{tags.slice(0, 3).map(tag => (
				<span style="background: white; color: var(--text-muted); font-size: 0.65rem; padding: 2px 8px; border-radius: 6px; font-weight: 600; border: 1px solid var(--border-color);">
					#{tag}
				</span>
			))}
		</div>

		<h3 style="font-size: 1.15rem; font-weight: 800; line-height: 1.4; color: var(--text-main);">
			<a href={`/blog/${slug}`} style="color: inherit;" class="card-link">
				{title}
			</a>
		</h3>

		<p style="color: var(--text-muted); font-size: 0.85rem; line-height: 1.6; flex-grow: 1;">
			{description}
		</p>
	</div>
</div>

<style>
	.card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-md);
		border-color: rgba(0, 82, 255, 0.15);
		background: #FFFFFF !important;
	}
	.card:hover .card-img {
		transform: scale(1.03);
	}
	.card-link:hover {
		color: var(--accent-blue) !important;
	}
</style>
