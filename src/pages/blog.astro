---
import ControlTowerLayout from '../layouts/ControlTowerLayout.astro';
import db from '../data/db.json';
import { getCollection } from 'astro:content';

// Fetch published logs from both sources
const postsCollection = await getCollection('blog');
const dbPosts = db.posts;

const allPosts = [
	...postsCollection.map(p => ({
		id: p.id,
		title: p.data.title,
		description: p.data.description,
		tags: p.data.tags,
		pubDate: p.data.pubDate,
		status: p.data.status, // e.g. planning, in-progress, completed
		category: p.data.category,
		projectId: 'olivia-choi-wedding',
		heroImage: p.data.heroImage || '/images/olivia-wedding-hero.png'
	})),
	...dbPosts.map(p => ({
		id: p.id,
		title: p.title,
		description: p.description,
		tags: p.tags,
		pubDate: new Date(p.pubDate),
		status: p.projectId === 'general' ? 'completed' : 'in-progress',
		category: p.category,
		projectId: p.projectId,
		heroImage: '/images/olivia-wedding-hero.png'
	}))
];

// Sort posts: Pin 'Episode 0: The Origin' to the top, then sort by date desc
const sortedPosts = allPosts.sort((a, b) => {
	const aIsOrigin = a.category === 'Episode 0: The Origin';
	const bIsOrigin = b.category === 'Episode 0: The Origin';
	
	if (aIsOrigin && !bIsOrigin) return -1;
	if (!aIsOrigin && bIsOrigin) return 1;
	
	return b.pubDate.valueOf() - a.pubDate.valueOf();
});

// List of project folders from C:/appdev/
const projectsList = db.projects;
---

<ControlTowerLayout 
	title="AI 빌드 저널 | AI Experiment Lab"
	description="AI 비즈니스 모델 구축 프로젝트별 빌드 로그 및 마일스톤 에세이 기록지"
>
	<div class="bg-white min-h-screen py-20">
		<div class="max-w-6xl mx-auto px-6 space-y-12">
			
			<!-- Header Block -->
			<div class="text-center max-w-2xl mx-auto space-y-3">
				<span class="text-blue-600 font-bold text-xs uppercase tracking-widest">AI Build Logs Journal</span>
				<h1 class="text-4xl font-extrabold text-slate-900 tracking-tight">AI 빌드 저널</h1>
				<p class="text-slate-500 text-sm leading-relaxed">
					프로젝트 폴더 및 마일스톤 단계를 필터링하여 개발 여정을 가독성 좋게 추적하세요.
				</p>
			</div>

			<!-- Layout Grid: Sidebar on Left, Magazine Grid on Right -->
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
				
				<!-- Left Sidebar: Project Folders Filter -->
				<aside class="lg:col-span-3 space-y-6">
					<div class="bg-slate-50 border border-slate-100 rounded-[24px] p-6 shadow-sm sticky top-24 space-y-4">
						<h3 class="font-extrabold text-slate-900 text-xs uppercase tracking-wider mb-2">📁 Projects</h3>
						<div class="space-y-1" id="sidebar-projects">
							<button class="project-btn active-project-btn w-full text-left text-xs font-bold px-3 py-2 rounded-xl transition flex justify-between items-center" data-project="all">
								<span>전체 프로젝트</span>
								<span class="bg-slate-200 text-slate-700 text-[10px] font-semibold px-2 py-0.5 rounded-full">{allPosts.length}</span>
							</button>
							<button class="project-btn w-full text-left text-xs font-bold px-3 py-2 rounded-xl transition flex justify-between items-center" data-project="general">
								<span>💡 General Essays</span>
								<span class="bg-white border border-slate-200 text-slate-600 text-[10px] font-semibold px-2 py-0.5 rounded-full">{allPosts.filter(p => p.projectId === 'general').length}</span>
							</button>
							{projectsList.map(proj => {
								const projPosts = allPosts.filter(p => p.projectId === proj.id);
								return (
									<button class="project-btn w-full text-left text-xs font-bold px-3 py-2 rounded-xl transition flex justify-between items-center" data-project={proj.id}>
										<span class="truncate pr-2">📁 {proj.name.replace(' (Sync)', '')}</span>
										<span class="bg-white border border-slate-200 text-slate-600 text-[10px] font-semibold px-2 py-0.5 rounded-full flex-shrink-0">{projPosts.length}</span>
									</button>
								);
							})}
						</div>
					</div>
				</aside>

				<!-- Right Column: Content Logs -->
				<main class="lg:col-span-9 space-y-8">
					<!-- Top Navigation & Milestones Filtering -->
					<div class="bg-slate-50 border border-slate-100 rounded-[24px] p-5 shadow-sm flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
						<span class="text-xs font-bold text-slate-700">Milestone Stage:</span>
						
						<!-- Milestone Stage Filters -->
						<div class="flex flex-wrap gap-1.5" id="milestone-filters">
							<button class="milestone-btn active-milestone-btn text-[11px] font-bold px-3 py-1.5 rounded-lg border border-slate-200 bg-white text-slate-600 transition" data-status="all">전체</button>
							<button class="milestone-btn text-[11px] font-bold px-3 py-1.5 rounded-lg border border-slate-200 text-slate-600 transition" data-status="planning">Planning (기획)</button>
							<button class="milestone-btn text-[11px] font-bold px-3 py-1.5 rounded-lg border border-slate-200 text-slate-600 transition" data-status="in-progress">Developing (개발)</button>
							<button class="milestone-btn text-[11px] font-bold px-3 py-1.5 rounded-lg border border-slate-200 text-slate-600 transition" data-status="completed">Completed (완료)</button>
							<button class="milestone-btn text-[11px] font-bold px-3 py-1.5 rounded-lg border border-slate-200 text-slate-600 transition" data-status="failed">Failed (실패)</button>
						</div>
					</div>

					<!-- Magazine Grid Layout -->
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6 transition-opacity duration-300" id="magazine-posts-grid">
						{sortedPosts.map(post => {
							const isOrigin = post.category === 'Episode 0: The Origin';
							return (
								<div 
									class={`blog-card border rounded-[24px] p-6 transition-all duration-300 flex flex-col gap-3 shadow-sm hover:shadow-md cursor-pointer ${
										isOrigin 
											? 'border-amber-300 bg-amber-50/10 shadow-amber-50/30 hover:border-amber-400 md:col-span-2' 
											: 'border-slate-100 bg-slate-50 hover:bg-white'
									}`} 
									data-project={post.projectId}
									data-status={post.status}
									data-category={post.category}
								>
									<div class="flex items-center gap-2 flex-wrap text-[10px]">
										{isOrigin ? (
											<span class="bg-amber-100 text-amber-900 font-extrabold px-3 py-1 rounded-full border border-amber-200 flex items-center gap-1 animate-pulse">
												🎬 Episode 0: The Origin
											</span>
										) : (
											<span class="bg-white border border-slate-200 text-blue-600 font-bold px-2 py-0.5 rounded-md">
												{post.category}
											</span>
										)}
										<span class="text-slate-400 font-mono">
											📅 {new Date(post.pubDate).toLocaleDateString('ko-KR')}
										</span>
									</div>

									<h3 class={`font-extrabold text-slate-900 leading-snug hover:text-blue-600 transition ${isOrigin ? 'text-xl' : 'text-base'}`}>
										<a href={`/blog/${post.id}`}>
											{post.title}
										</a>
									</h3>

									<p class="text-slate-500 text-xs leading-relaxed line-clamp-2">
										{post.description}
									</p>

									<div class="border-t border-slate-200/50 pt-3 flex justify-between items-center text-[10px] text-slate-400 mt-1">
										<div class="flex gap-1">
											{post.tags && post.tags.slice(0, 3).map(tag => (
												<span class="text-slate-400 font-medium">#{tag}</span>
											))}
										</div>
										<span class="font-bold text-slate-500 capitalize font-mono">🚀 {post.status === 'in-progress' ? 'Developing' : post.status}</span>
									</div>
								</div>
							);
						})}
					</div>

					<div id="no-posts-alert" class="hidden text-center py-20 bg-slate-50 border border-slate-100 rounded-[24px] text-slate-400 shadow-sm">
						<span class="text-3xl">📭</span>
						<p class="font-bold mt-4">조건에 매칭되는 빌드 로그 에세이가 없습니다.</p>
					</div>

				</main>

			</div>

		</div>
	</div>
</ControlTowerLayout>

<style>
	.project-btn {
		background: transparent;
		color: #64748B;
	}
	.project-btn:hover {
		background: #FFFFFF;
		color: #0F172A;
	}
	.active-project-btn {
		background: #0052FF !important;
		color: white !important;
	}

	.active-milestone-btn {
		background: #0F172A !important;
		color: white !important;
		border-color: #0F172A !important;
	}

	/* Smooth fade filter transition */
	.blog-card {
		transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1), transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}
</style>

<script>
	const projectBtns = document.querySelectorAll('.project-btn');
	const milestoneBtns = document.querySelectorAll('.milestone-btn');
	const blogCards = document.querySelectorAll('.blog-card') as NodeListOf<HTMLElement>;
	const gridContainer = document.getElementById('magazine-posts-grid');
	const noPostsAlert = document.getElementById('no-posts-alert');

	let activeProject = 'all';
	let activeStatus = 'all';

	function applyFilter() {
		gridContainer!.style.opacity = '0.3';

		setTimeout(() => {
			let visibleCount = 0;

			blogCards.forEach(card => {
				const cardProj = card.getAttribute('data-project');
				const cardStatus = card.getAttribute('data-status');

				const matchProj = activeProject === 'all' || cardProj === activeProject;
				const normalizedStatus = cardStatus === 'in-progress' ? 'in-progress' : cardStatus;
				const matchStatus = activeStatus === 'all' || normalizedStatus === activeStatus;

				if (matchProj && matchStatus) {
					card.style.display = 'flex';
					visibleCount++;
				} else {
					card.style.display = 'none';
				}
			});

			if (visibleCount === 0) {
				noPostsAlert!.classList.remove('hidden');
			} else {
				noPostsAlert!.classList.add('hidden');
			}

			gridContainer!.style.opacity = '1';
		}, 200);
	}

	projectBtns.forEach(btn => {
		btn.addEventListener('click', (e) => {
			projectBtns.forEach(b => b.classList.remove('active-project-btn'));
			const current = e.currentTarget as HTMLButtonElement;
			current.classList.add('active-project-btn');
			
			activeProject = current.getAttribute('data-project') || 'all';
			applyFilter();
		});
	});

	milestoneBtns.forEach(btn => {
		btn.addEventListener('click', (e) => {
			milestoneBtns.forEach(b => b.classList.remove('active-milestone-btn'));
			const current = e.currentTarget as HTMLButtonElement;
			current.classList.add('active-milestone-btn');

			activeStatus = current.getAttribute('data-status') || 'all';
			applyFilter();
		});
	});
</script>
