---
import { getCollection } from 'astro:content';
import ControlTowerLayout from '../../layouts/ControlTowerLayout.astro';
import db from '../../data/db.json';

export async function getStaticPaths() {
	const postsCollection = await getCollection('blog');
	const dbPosts = db.posts;

	const allPosts = [
		...postsCollection.map(p => ({
			id: p.id,
			title: p.data.title,
			description: p.data.description,
			tags: p.data.tags,
			pubDate: p.data.pubDate,
			client: p.data.client || '',
			location: p.data.location || '',
			category: p.data.category,
			content: p.body,
			likes: 12,
			comments: [
				{ author: "사령관", text: "로컬 속도가 아주 만족스럽네요.", date: "2026-07-09T12:00:00Z" }
			]
		})),
		...dbPosts.map(p => ({
			id: p.id,
			title: p.title,
			description: p.description,
			tags: p.tags,
			pubDate: new Date(p.pubDate),
			client: p.projectId,
			location: 'Chicago, IL',
			category: p.category,
			content: p.content,
			likes: p.likes || 0,
			comments: p.comments || []
		}))
	];

	// Filter duplicates
	const seen = new Set();
	const uniquePosts = allPosts.filter(p => {
		const duplicate = seen.has(p.id);
		seen.add(p.id);
		return !duplicate;
	});

	return uniquePosts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

const post = Astro.props;

// Convert markdown to clean HTML client/server-side
function mdToHTML(md: string) {
	let html = md
		.replace(/^# (.*$)/gim, '<h1 class="text-3xl font-extrabold text-slate-900 border-b border-slate-100 pb-2 mb-4">$1</h1>')
		.replace(/^## (.*$)/gim, '<h2 class="text-xl font-bold text-slate-800 mt-8 mb-4">$1</h2>')
		.replace(/^### (.*$)/gim, '<h3 class="text-md font-semibold text-slate-700 mt-6 mb-2">$1</h3>')
		.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
		.replace(/\n\n/g, '</p><p class="text-slate-600 leading-relaxed mb-4">');

	// Wrap in paragraph if not already started
	if (!html.startsWith('<h1') && !html.startsWith('<h2') && !html.startsWith('<h3')) {
		html = '<p class="text-slate-600 leading-relaxed mb-4">' + html + '</p>';
	}

	// Visual Placeholders styling
	html = html.replace(/\[📷 이미지 추천 포인트: (.*?)\]/gim, `
		<div class="my-8 border border-dashed border-blue-200 bg-blue-50/40 rounded-xl p-5 flex items-start gap-4">
			<span class="text-2xl">📷</span>
			<div>
				<h4 class="text-xs font-bold text-blue-800 uppercase tracking-wide">Premium Visual Concept Recommendation</h4>
				<p class="text-xs text-blue-700 mt-1">$1</p>
				<span class="inline-flex items-center gap-1.5 mt-2 bg-blue-100 text-blue-800 text-[10px] font-semibold px-2 py-0.5 rounded">이미지 권장 가이드</span>
			</div>
		</div>
	`);

	return html;
}

const htmlContent = mdToHTML(post.content);

// Schema.org Structured Data
const schemaArticle = {
	"@context": "https://schema.org",
	"@type": post.category === "Build Log" ? "TechArticle" : "Article",
	"headline": post.title,
	"description": post.description,
	"datePublished": post.pubDate.toISOString(),
	"author": {
		"@type": "Organization",
		"name": "Chicago AI Web Factory"
	},
	"publisher": {
		"@type": "Organization",
		"name": "Chicago AI Web Factory",
		"logo": {
			"@type": "ImageObject",
			"url": "https://chicago-ai-web-factory.web.app/favicon.svg"
		}
	}
};
---

<ControlTowerLayout 
	title={post.title} 
	description={post.description}
>
	<!-- Schema.org JSON-LD -->
	<script type="application/ld+json" set:html={JSON.stringify(schemaArticle)} />

	<article class="max-w-3xl mx-auto py-16 px-4 sm:px-6 lg:px-8">
		
		<!-- Tags -->
		<div class="flex flex-wrap gap-2 mb-6">
			{post.tags.map(tag => (
				<span class="bg-blue-50 text-blue-600 text-xs font-semibold px-3 py-1 rounded-full border border-blue-100">
					#{tag}
				</span>
			))}
		</div>

		<!-- Title -->
		<h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 tracking-tight leading-tight mb-6">
			{post.title}
		</h1>

		<!-- Post Info Meta -->
		<div class="flex flex-wrap items-center gap-4 text-xs text-slate-400 border-b border-slate-100 pb-6 mb-10">
			<span>📅 {post.pubDate.toLocaleDateString('ko-KR')}</span>
			{post.client && <span>👤 클라이언트: {post.client}</span>}
			{post.location && <span>📍 위치: {post.location}</span>}
			<span class="bg-blue-50 text-blue-600 font-semibold px-2 py-0.5 rounded border border-blue-100">
				{post.category}
			</span>
		</div>

		<!-- Clean HTML Post Content -->
		<div class="prose max-w-none text-slate-800 leading-relaxed" set:html={htmlContent} />

		<!-- Interactive Engagement Panel (Like / Share) -->
		<div class="border-y border-slate-200 py-6 my-12 flex justify-between items-center flex-wrap gap-4">
			<div class="flex items-center gap-3">
				<button id="btn-like" class="bg-slate-50 hover:bg-red-50 hover:text-red-600 text-slate-700 font-bold border border-slate-200 rounded-xl px-4 py-2.5 text-sm transition flex items-center gap-2">
					❤️ 좋아요 <span id="like-counter">{post.likes}</span>
				</button>
			</div>
			
			<button id="btn-share" class="bg-white hover:bg-slate-100 text-slate-700 font-bold border border-slate-200 rounded-xl px-4 py-2.5 text-sm transition flex items-center gap-2">
				🔗 링크 공유하기
			</button>
		</div>

		<!-- Firestore / Client Side Comments section -->
		<div class="space-y-6">
			<h3 class="font-extrabold text-xl text-slate-900 flex items-center gap-2">
				💬 피드백 및 댓글
			</h3>

			<!-- Add comment form -->
			<form id="comment-form" class="bg-slate-50 border border-slate-200 rounded-2xl p-6 space-y-4">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
					<input type="text" id="comment-author" placeholder="닉네임" required class="w-full text-sm border border-slate-200 rounded-lg p-2.5 outline-none focus:border-blue-600 bg-white" />
				</div>
				<textarea id="comment-text" rows="3" placeholder="의견을 남겨주세요..." required class="w-full text-sm border border-slate-200 rounded-lg p-3 outline-none focus:border-blue-600 bg-white resize-none"></textarea>
				<button type="submit" class="bg-slate-900 hover:bg-black text-white text-xs font-bold px-4 py-2.5 rounded-lg transition">
					댓글 등록
				</button>
			</form>

			<!-- Comments list -->
			<div id="comments-list" class="space-y-4 pt-4">
				{post.comments.map(c => (
					<div class="bg-white border border-slate-100 rounded-xl p-4 shadow-sm">
						<div class="flex justify-between items-center text-xs mb-2">
							<span class="font-bold text-slate-800">👤 {c.author}</span>
							<span class="text-slate-400">{new Date(c.date).toLocaleDateString('ko-KR')}</span>
						</div>
						<p class="text-sm text-slate-600 leading-relaxed">{c.text}</p>
					</div>
				))}
			</div>
		</div>

	</article>
</ControlTowerLayout>

<script is:inline define:vars={{ postId: post.id, initialLikes: post.likes, initialComments: post.comments }}>
	// Client side local updates to simulate dynamic likes and comment updates
	const storageKey = `post_engagement_${postId}`;
	let state = {
		likes: initialLikes,
		comments: initialComments
	};

	const saved = localStorage.getItem(storageKey);
	if (saved) {
		state = JSON.parse(saved);
	} else {
		localStorage.setItem(storageKey, JSON.stringify(state));
	}

	// UI update
	const likeCounter = document.getElementById('like-counter');
	const commentsList = document.getElementById('comments-list');
	const likeBtn = document.getElementById('btn-like');
	const shareBtn = document.getElementById('btn-share');
	const commentForm = document.getElementById('comment-form');

	if (likeCounter) likeCounter.textContent = state.likes;
	
	function renderComments() {
		if (!commentsList) return;
		commentsList.innerHTML = '';
		state.comments.forEach(c => {
			const div = document.createElement('div');
			div.className = 'bg-white border border-slate-100 rounded-xl p-4 shadow-sm';
			div.innerHTML = `
				<div class="flex justify-between items-center text-xs mb-2">
					<span class="font-bold text-slate-800">👤 ${c.author}</span>
					<span class="text-slate-400">${new Date(c.date).toLocaleDateString('ko-KR')}</span>
				</div>
				<p class="text-sm text-slate-600 leading-relaxed">${c.text}</p>
			`;
			commentsList.appendChild(div);
		});
	}

	renderComments();

	likeBtn?.addEventListener('click', () => {
		state.likes++;
		likeCounter.textContent = state.likes;
		localStorage.setItem(storageKey, JSON.stringify(state));
		
		// Optional: also push update to client-wide database to persist globally
		const globalDb = JSON.parse(localStorage.getItem('control_tower_db') || '{}');
		if (globalDb && globalDb.posts) {
			const p = globalDb.posts.find(item => item.id === postId);
			if (p) {
				p.likes = state.likes;
				localStorage.setItem('control_tower_db', JSON.stringify(globalDb));
			}
		}
	});

	shareBtn?.addEventListener('click', () => {
		navigator.clipboard.writeText(window.location.href).then(() => {
			alert('게시글 주소가 복사되었습니다!');
		});
	});

	commentForm?.addEventListener('submit', (e) => {
		e.preventDefault();
		const authorEl = document.getElementById('comment-author');
		const textEl = document.getElementById('comment-text');
		const author = authorEl.value.trim();
		const text = textEl.value.trim();

		if (!author || !text) return;

		const newComment = {
			author,
			text,
			date: new Date().toISOString()
		};

		state.comments.unshift(newComment);
		localStorage.setItem(storageKey, JSON.stringify(state));
		renderComments();

		// Optional: save to client-wide globalDb
		const globalDb = JSON.parse(localStorage.getItem('control_tower_db') || '{}');
		if (globalDb && globalDb.posts) {
			const p = globalDb.posts.find(item => item.id === postId);
			if (p) {
				p.comments = state.comments;
				localStorage.setItem('control_tower_db', JSON.stringify(globalDb));
			}
		}

		authorEl.value = '';
		textEl.value = '';
	});
</script>
