---
import { getCollection } from 'astro:content';
import db from '../data/db.json';

const postsCollection = await getCollection('blog');
const dbPosts = db.posts;

const allLogs = [
	...postsCollection.map(p => {
		const parts = p.id.split('/');
		const projectId = parts[0];
		const simpleId = parts.pop() || p.id;
		return {
			id: simpleId,
			title: p.data.title,
			description: p.data.description,
			pubDate: p.data.pubDate,
			heroImage: p.data.heroImage || '/images/olivia-wedding-hero.png'
		};
	}),
	...dbPosts.map(p => ({
		id: p.id,
		title: p.title,
		description: p.description,
		pubDate: new Date(p.pubDate),
		heroImage: '/images/dalo-logo.svg'
	}))
];
const sortedLogs = allLogs.sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());

function formatDate(date: string | number | Date) {
    return new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>DALO Fictions</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Spectral:wght@600;700&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #fffdf7;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            color: #363737;
        }
        .font-serif {
            font-family: 'Spectral', Georgia, serif;
        }
    </style>
</head>
<body class="min-h-screen text-[#363737]">
    
    <!-- Top Bar -->
    <header class="flex items-center justify-between px-5 h-[88px] max-w-[1100px] mx-auto">
        <div class="flex items-center gap-4 flex-1">
            <a href="/" class="block w-10 h-10 rounded shadow-sm overflow-hidden border border-[#e6e4de] bg-white">
                <img src="/images/dalo-logo.svg" alt="DALO Logo" class="w-full h-full object-cover"/>
            </a>
        </div>
        <div class="flex-1 flex justify-center">
            <a href="/" class="font-serif text-[28px] sm:text-[32px] font-bold tracking-[0.15em] uppercase text-[#111111] hover:text-[#5272cc] transition-colors whitespace-nowrap">
                DALO Fictions
            </a>
        </div>
        <div class="flex items-center gap-4 flex-1 justify-end">
            <button class="text-[#363737] hover:text-black hidden sm:block">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
            </button>
            <button class="text-[#363737] hover:text-black hidden sm:block">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" x2="12" y1="2" y2="15"></line></svg>
            </button>
            <button class="bg-[#5272cc] hover:bg-[#3e62c6] text-white font-semibold text-[15px] px-[14px] py-1.5 rounded-[4px] transition-colors">
                Subscribe
            </button>
            <button class="text-[#363737] hover:text-black font-medium text-[15px] px-1 hidden sm:block">
                Sign in
            </button>
        </div>
    </header>

    <!-- Nav Bar -->
    <nav class="border-b border-[#e6e4de] h-12 flex justify-center">
        <div class="flex h-full gap-8">
            <a href="/" class="flex items-center h-full text-[13px] font-semibold text-[#757575] hover:text-black transition-colors">Home</a>
            <a href="/archive" class="flex items-center h-full text-[13px] font-semibold text-black border-b-2 border-black relative top-[1px]">Archive</a>
            <a href="/about" class="flex items-center h-full text-[13px] font-semibold text-[#757575] hover:text-black transition-colors">About</a>
        </div>
    </nav>

    <!-- Content -->
    <main class="max-w-[728px] mx-auto px-4 pt-10 pb-24">
        
        <!-- Filters -->
        <div class="flex justify-between items-center mb-8 border border-[#e6e4de] rounded bg-[#f0eee8] w-fit p-[3px]">
            <button class="text-[13px] font-medium px-4 py-1 text-[#757575] hover:text-black rounded">Latest</button>
            <button class="text-[13px] font-medium px-4 py-1 text-[#757575] hover:text-black rounded">Top</button>
            <button class="text-[13px] font-medium px-4 py-1 bg-white shadow-sm rounded text-black">Discussions</button>
        </div>

        <!-- Posts List -->
        <div class="flex flex-col">
            {sortedLogs.map((post, idx) => (
                <article class="flex justify-between gap-6 py-6 border-b border-[#e6e4de] group cursor-pointer" onclick={`window.location.href='/blog/${post.id}'`}>
                    
                    <div class="flex-1 flex flex-col">
                        <h2 class="text-[20px] font-bold leading-snug mb-1 text-[#111111] group-hover:text-[#5272cc] transition-colors font-serif">
                            {post.title}
                        </h2>
                        <p class="text-[15px] text-[#757575] mb-2 leading-snug line-clamp-2">
                            {post.description}
                        </p>
                        <div class="text-[11px] font-medium text-[#92918e] uppercase tracking-wide mt-2">
                            {formatDate(post.pubDate)} <span class="mx-1">•</span> Operator
                        </div>
                    </div>

                    <div class="w-[200px] h-[133px] sm:w-[240px] sm:h-[160px] rounded overflow-hidden shrink-0 border border-[#e6e4de] bg-white">
                        <img src={post.heroImage} alt={post.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                    </div>
                </article>
            ))}
        </div>

    </main>

    <footer class="mt-20 py-10 bg-[#f0eee8] border-t border-[#e6e4de] flex flex-col items-center justify-center gap-4 text-[13px] text-[#757575]">
        <div>© 2026 DALO Fictions · Privacy · Terms</div>
    </footer>
</body>
</html>
