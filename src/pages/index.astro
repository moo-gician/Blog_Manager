---
import { getCollection } from 'astro:content';
import db from '../data/db.json';

// Fetch public build logs
const postsCollection = await getCollection('blog');
const dbPosts = db.posts;

// Merge and sort published logs
const allLogs = [
	...postsCollection.map(p => {
		const parts = p.id.split('/');
		const projectId = parts[0];
		const simpleId = parts.pop() || p.id;
		return {
			id: simpleId,
			title: p.data.title,
			description: p.data.description,
			tags: p.data.tags,
			pubDate: p.data.pubDate,
			status: p.data.status,
			category: p.data.category || 'Uncategorized',
			projectId: projectId,
			heroImage: p.data.heroImage || '/images/olivia-wedding-hero.png'
		};
	}),
	...dbPosts.map(p => ({
		id: p.id,
		title: p.title,
		description: p.description,
		tags: p.tags,
		pubDate: new Date(p.pubDate),
		status: p.projectId === 'general' ? 'completed' : 'in-progress',
		category: p.category || 'Uncategorized',
		projectId: p.projectId,
		heroImage: '/images/dalo-logo.svg'
	}))
];

const sortedLogs = allLogs.sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Archive - DALO Fictions</title>
	<!-- Substack style fonts (Inter or Spectral-like) -->
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Spectral:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
	<script src="https://cdn.tailwindcss.com"></script>
	
	<style>
		:root {
			--bg-color: #fffdf7;
			--accent: #5272cc;
			--text-main: #111111;
			--text-muted: #555555;
			--border: #e6e4de;
		}
		body {
			margin: 0;
			padding: 0;
			background-color: var(--bg-color);
			color: var(--text-main);
			font-family: 'Inter', -apple-system, sans-serif;
			-webkit-font-smoothing: antialiased;
		}
		.font-serif {
			font-family: 'Spectral', Georgia, serif;
		}
	</style>
</head>
<body class="bg-[#fffdf7] min-h-screen">

	<!-- Top Bar -->
	<header class="flex items-center justify-between px-5 h-[88px] border-b border-[#e6e4de] max-w-[1100px] mx-auto">
		<div class="flex items-center gap-3 flex-1">
			<a href="/" class="flex items-center gap-3">
				<div class="w-10 h-10 bg-white rounded flex items-center justify-center overflow-hidden shrink-0 border border-gray-100">
					<img src="/images/dalo-logo.svg" alt="Logo" class="w-full h-full object-cover" />
				</div>
				<h1 class="font-serif text-[22px] font-bold tracking-tight m-0 text-gray-900 hidden sm:block">DALO Fictions</h1>
			</a>
		</div>
		<div class="flex items-center gap-2 sm:gap-4 flex-1 justify-end">
			<button aria-label="Search" class="text-gray-600 hover:text-gray-900 hidden sm:block">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
			</button>
			<button class="bg-[#5272cc] hover:bg-[#3e62c6] text-white font-semibold text-sm px-4 py-2 rounded-md transition">
				Subscribe
			</button>
			<button class="text-gray-600 hover:text-gray-900 font-semibold text-sm px-2">
				Sign in
			</button>
		</div>
	</header>

	<!-- Nav Bar -->
	<nav class="border-b border-[#e6e4de] h-12 flex justify-center max-w-[1100px] mx-auto">
		<div class="flex h-full gap-8">
			<a href="/" class="flex items-center h-full text-sm font-semibold text-gray-500 hover:text-gray-900 transition">Home</a>
			<a href="/archive" class="flex items-center h-full text-sm font-semibold text-gray-900 border-b-2 border-gray-900">Archive</a>
			<a href="/about" class="flex items-center h-full text-sm font-semibold text-gray-500 hover:text-gray-900 transition">About</a>
		</div>
	</nav>

	<!-- Archive Content Area -->
	<main class="max-w-[728px] mx-auto px-4 pt-10 pb-24">
		
		<!-- Filters -->
		<div class="flex justify-between items-center mb-8 border border-[#e6e4de] rounded-md p-1 bg-white/50 w-fit">
			<button class="text-sm font-medium px-4 py-1.5 text-gray-600 hover:text-gray-900 rounded">Latest</button>
			<button class="text-sm font-medium px-4 py-1.5 text-gray-600 hover:text-gray-900 rounded">Top</button>
			<button class="text-sm font-medium px-4 py-1.5 bg-white shadow-sm rounded text-gray-900">Discussions</button>
		</div>

		<!-- Post List -->
		<div class="flex flex-col gap-6">
			{sortedLogs.map(post => (
				<article class="flex flex-col-reverse sm:flex-row gap-6 pb-6 border-b border-[#e6e4de] group cursor-pointer" onclick={`window.location.href='/blog/${post.id}'`}>
					
					<!-- Left: Content -->
					<div class="flex-1 flex flex-col justify-between">
						<div>
							<h2 class="text-[22px] font-serif font-bold leading-tight mb-2 text-gray-900 group-hover:text-gray-600 transition">
								{post.title}
							</h2>
							<p class="text-[15px] text-gray-600 mb-3 line-clamp-2">
								{post.description}
							</p>
						</div>
						
						<!-- Metadata & Actions -->
						<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 sm:gap-0 mt-4 sm:mt-0">
							<div class="text-[12px] font-medium text-gray-500 uppercase tracking-wide">
								{new Date(post.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })} <span class="mx-1 text-gray-300">•</span> Operator
							</div>
							
							<div class="flex items-center gap-4 text-gray-400">
								<div class="flex items-center gap-1.5 hover:text-gray-600 transition">
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path></svg>
									<span class="text-xs font-medium">{Math.floor(Math.random() * 500) + 10}</span>
								</div>
								<div class="flex items-center gap-1.5 hover:text-gray-600 transition">
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path></svg>
									<span class="text-xs font-medium">{Math.floor(Math.random() * 50) + 2}</span>
								</div>
								<div class="hover:text-gray-600 transition">
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" x2="12" y1="2" y2="15"></line></svg>
								</div>
							</div>
						</div>
					</div>

					<!-- Right: Image -->
					<div class="w-full sm:w-[240px] aspect-[1.5] sm:aspect-auto sm:h-[160px] rounded bg-gray-100 overflow-hidden shrink-0 border border-gray-100">
						<img src={post.heroImage} alt={post.title} class="w-full h-full object-cover" />
					</div>
				</article>
			))}
		</div>

	</main>
</body>
</html>
