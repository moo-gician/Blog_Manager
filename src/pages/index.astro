---
import ControlTowerLayout from '../layouts/ControlTowerLayout.astro';
import { getCollection } from 'astro:content';
import db from '../data/db.json';

// Fetch public build logs
const postsCollection = await getCollection('blog');
const dbPosts = db.posts;

// Merge and sort published logs
// Removed dynamic localstorage/operator injection per user request
const allLogs = [
	...postsCollection.map(p => {
		const parts = p.id.split('/');
		const projectId = parts[0];
		const simpleId = parts.pop() || p.id;
		return {
			id: simpleId,
			title: p.data.title,
			description: p.data.description,
			tags: p.data.tags,
			pubDate: p.data.pubDate,
			status: p.data.status,
			category: p.data.category || 'Uncategorized',
			projectId: projectId,
			heroImage: p.data.heroImage || '/images/olivia-wedding-hero.png'
		};
	}),
	...dbPosts.map(p => ({
		id: p.id,
		title: p.title,
		description: p.description,
		tags: p.tags,
		pubDate: new Date(p.pubDate),
		status: p.projectId === 'general' ? 'completed' : 'in-progress',
		category: p.category || 'Uncategorized',
		projectId: p.projectId,
		heroImage: '/images/dalo-logo.svg'
	}))
];

const sortedLogs = allLogs.sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());
---

<ControlTowerLayout 
	title="DALO Fictions | Substack Style"
	description="all models are wrong, but some are useful"
>
	<!-- Substack style background (#fffdf7) overriding layout default -->
	<div class="bg-[#fffdf7] min-h-screen font-sans text-[#111111] pb-32">
		
		<!-- Hero / Header Section -->
		<div class="max-w-3xl mx-auto px-4 pt-20 pb-16 text-center border-b border-gray-200/60">
			<!-- Logo / Avatar -->
			<div class="flex justify-center mb-6">
				<img src="/images/dalo-logo.svg" alt="DALO Logo" class="w-24 h-24 rounded-full border border-gray-200 p-2 bg-white object-cover" />
			</div>
			
			<h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4">
				DALO Fictions
			</h1>
			<p class="text-lg md:text-xl text-gray-600 mb-8 font-medium">
				all models are wrong, but some are useful
			</p>
			
			<div class="flex items-center justify-center gap-2 mb-10 text-sm text-gray-500 font-medium">
				<span>By Operator</span>
				<span>·</span>
				<span>Over 32,000 subscribers</span>
			</div>

			<!-- Subscribe Form (Substack Style CTA) -->
			<div class="max-w-md mx-auto">
				<form class="flex flex-col sm:flex-row gap-2" onsubmit="event.preventDefault();">
					<input 
						type="email" 
						placeholder="Type your email..." 
						class="flex-1 px-4 py-3 rounded-lg border border-gray-300 bg-white focus:outline-none focus:border-[#5272cc] focus:ring-1 focus:ring-[#5272cc] transition"
					/>
					<button 
						type="submit" 
						class="bg-[#5272cc] hover:bg-[#3e62c6] text-white font-bold py-3 px-6 rounded-lg transition"
					>
						Subscribe
					</button>
				</form>
				<p class="text-xs text-gray-400 mt-4 text-center">
					By subscribing, you agree to Substack's Terms of Use.
				</p>
			</div>
		</div>

		<!-- Main Feed Container -->
		<div class="max-w-5xl mx-auto px-4 pt-16">
			
			<!-- Featured Post (Magaziney Layout) -->
			{sortedLogs.length > 0 && (
				<article class="mb-20 group cursor-pointer" onclick={`window.location.href='/blog/${sortedLogs[0].id}'`}>
					<div class="w-full aspect-video md:aspect-[21/9] overflow-hidden rounded-xl mb-6 bg-gray-100 border border-gray-100">
						<img src={sortedLogs[0].heroImage} alt={sortedLogs[0].title} class="w-full h-full object-cover group-hover:opacity-95 transition duration-300" />
					</div>
					<div class="max-w-3xl mx-auto text-center px-4">
						<span class="text-[#5272cc] font-bold text-xs tracking-widest uppercase mb-3 block">
							{sortedLogs[0].category}
						</span>
						<h2 class="text-3xl md:text-5xl font-extrabold mb-4 group-hover:text-[#5272cc] transition duration-200">
							{sortedLogs[0].title}
						</h2>
						<p class="text-lg text-gray-600 mb-6 line-clamp-3">
							{sortedLogs[0].description}
						</p>
						<div class="text-sm font-medium text-gray-500">
							Operator · {new Date(sortedLogs[0].pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
						</div>
					</div>
				</article>
			)}

			<!-- Recent Posts Divider -->
			<div class="flex items-center gap-4 mb-10">
				<h3 class="font-bold text-xl text-gray-900">Recent Posts</h3>
				<div class="h-px bg-gray-200 flex-1"></div>
			</div>

			<!-- Grid Posts (3-Column Layout) -->
			<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-10">
				{sortedLogs.slice(1).map(post => (
					<article class="group cursor-pointer flex flex-col h-full" onclick={`window.location.href='/blog/${post.id}'`}>
						<div class="w-full aspect-video overflow-hidden rounded-lg mb-4 bg-gray-100 border border-gray-100">
							<img src={post.heroImage} alt={post.title} class="w-full h-full object-cover group-hover:opacity-95 transition duration-300" />
						</div>
						<span class="text-[#5272cc] font-bold text-[10px] tracking-wider uppercase mb-2">
							{post.category}
						</span>
						<h3 class="text-xl font-bold mb-2 leading-tight group-hover:text-[#5272cc] transition duration-200 line-clamp-2">
							{post.title}
						</h3>
						<p class="text-gray-600 text-sm mb-4 line-clamp-2 flex-grow">
							{post.description}
						</p>
						<div class="text-xs font-medium text-gray-400 mt-auto">
							Operator · {new Date(post.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
						</div>
					</article>
				))}
			</div>

		</div>
	</div>
</ControlTowerLayout>
