---
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>About | DALO Fictions</title>
    <meta name="description" content="DALO Fictions is a public build journal of an AI entrepreneur in Chicago, documenting the raw journey of building AI businesses for local businesses." />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Spectral:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #fffdf7;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            color: #363737;
        }
        .font-spectral {
            font-family: 'Spectral', Georgia, serif;
        }
        .prose-body p {
            font-family: 'Spectral', Georgia, serif;
            font-size: 19px;
            line-height: 30px;
            color: #5d5437;
            margin-bottom: 1.25rem;
        }
        .prose-body h3 {
            font-family: 'Inter', sans-serif;
            font-size: 26px;
            font-weight: 700;
            color: #111111;
            margin-top: 2rem;
            margin-bottom: 0.75rem;
        }
        .prose-body ol {
            font-family: 'Spectral', Georgia, serif;
            font-size: 19px;
            line-height: 30px;
            color: #5d5437;
            padding-left: 1.5rem;
            list-style-type: decimal;
            margin-bottom: 1.25rem;
        }
        .prose-body ol li {
            margin-bottom: 0.75rem;
        }
        .prose-body a {
            color: #5272cc;
            text-decoration: underline;
        }
        .blockquote-box {
            background-color: #f0eee8;
            border-radius: 8px;
            padding: 20px 24px;
            text-align: center;
            margin: 2rem 0;
        }
        .blockquote-box p {
            font-family: 'Inter', sans-serif;
            font-size: 15px;
            color: #5d5437;
            line-height: 24px;
        }
    </style>
</head>
<body class="min-h-screen">

    <!-- Top Bar -->
    <header class="flex items-center justify-between px-5 h-[88px] max-w-[1100px] mx-auto">
        <div class="flex items-center gap-4 flex-1">
            <a href="/" class="block w-10 h-10 rounded shadow-sm overflow-hidden border border-[#e6e4de] bg-white">
                <img src="/images/dalo-logo.svg" alt="DALO Logo" class="w-full h-full object-cover"/>
            </a>
        </div>
        <div class="flex-1 flex justify-center">
            <a href="/" class="font-spectral text-[28px] sm:text-[32px] font-bold tracking-[0.15em] uppercase text-[#111111] hover:text-[#5272cc] transition-colors whitespace-nowrap">
                DALO Fictions
            </a>
        </div>
        <div class="flex items-center gap-4 flex-1 justify-end">
            <button class="text-[#363737] hover:text-black hidden sm:block">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
            </button>
            <button class="text-[#363737] hover:text-black hidden sm:block">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" x2="12" y1="2" y2="15"></line></svg>
            </button>
            <button class="bg-[#5272cc] hover:bg-[#3e62c6] text-white font-semibold text-[15px] px-[14px] py-1.5 rounded-[4px] transition-colors">
                Subscribe
            </button>
            <button class="text-[#363737] hover:text-black font-medium text-[15px] px-1 hidden sm:block">
                Sign in
            </button>
        </div>
    </header>

    <!-- Nav Bar -->
    <nav class="border-b border-[#e6e4de] h-12 flex justify-center">
        <div class="flex h-full gap-8">
            <a href="/" class="flex items-center h-full text-[13px] font-semibold text-[#757575] hover:text-black transition-colors">Home</a>
            <a href="/archive" class="flex items-center h-full text-[13px] font-semibold text-[#757575] hover:text-black transition-colors">Archive</a>
            <a href="/about" class="flex items-center h-full text-[13px] font-semibold text-black border-b-2 border-[#5d5437] relative top-[1px]">About</a>
        </div>
    </nav>

    <!-- Content -->
    <main class="max-w-[728px] mx-auto px-4 pt-12 pb-24 prose-body">

        <!-- Welcome Heading -->
        <h1 class="text-[38px] font-bold text-[#111111] leading-tight mb-4 font-spectral">Welcome to DALO Fictions</h1>

        <p>
            Subscribe to follow the real-time build journal of an AI entrepreneur in Chicago. Every post is a raw, unfiltered account of the wins, losses, and hard-won insights that come from building AI businesses for local businesses.
        </p>

        <!-- Inline CTA -->
        <div class="flex my-6 max-w-[420px]">
            <input id="email-top" type="email" placeholder="Type your email..." class="flex-1 px-4 py-2.5 text-[15px] bg-[#f0eee8] border border-[#5272cc] border-r-0 rounded-l-[8px] outline-none focus:bg-white transition-colors text-[#363737]" />
            <button id="btn-subscribe-top" class="bg-[#5272cc] hover:bg-[#3e62c6] text-white font-semibold text-[15px] px-5 py-2.5 rounded-r-[8px] transition-colors whitespace-nowrap">
                Subscribe
            </button>
        </div>

        <hr class="border-[#e6e4de] my-8" />

        <!-- What is DALO Fictions? -->
        <h3>What is DALO Fictions?</h3>
        <p>
            This blog is the real-time build log of DALO — an AI venture born in the cold winds of Chicago. In the city's offline economy, I found that small local businesses were being abandoned by expensive marketing agencies that promised everything and delivered nothing.
        </p>
        <p>
            DALO was built to fix that. The core idea: combine a <strong>high-performance static web</strong> with an <strong>automated AI content pipeline</strong> to give local businesses the unfair advantage once reserved for enterprise brands. Every post here documents the actual journey — the late nights, the failed deploys, the breakthrough moments, and the clients who made it real.
        </p>

        <hr class="border-[#e6e4de] my-8" />

        <!-- Who are you? -->
        <h3>Who are you?</h3>
        <p>
            I'm <strong>Operator</strong> — the founder of DALO. My authority here comes from doing, not theorizing:
        </p>
        <ol>
            <li>
                I've built and shipped multiple production AI systems for real clients in Chicago's local market — from premium wedding photography portfolios to neighborhood restaurant marketing engines.
            </li>
            <li>
                I've failed publicly and often. The first version of the DALO AI engine was too slow and cost me a massive cloud bill. I hit API rate limits at the worst moment. I broke trust with clients. All of it is logged here, honestly.
            </li>
            <li>
                I operate by a strict system: every decision, every failure, and every technical insight gets documented in <code>plan.md</code>, <code>context.md</code>, and <code>todo.md</code> — the three pillars of the DALO Memory System. Build in public. No airbrushing.
            </li>
        </ol>

        <hr class="border-[#e6e4de] my-8" />

        <!-- Where do I start? -->
        <h3>Where do I start?</h3>
        <p>Here are a few posts that will give you a feel for what DALO Fictions is really about:</p>
        <ol>
            <li>
                <a href="/blog/olivia-choi-wedding"><strong>Olivia Choi Photography — Premium Portfolio</strong></a>: The first DALO client project. An ultra-fast portfolio site built and deployed in a single sprint, with a live AI marketing engine underneath.
            </li>
            <li>
                <a href="/operator"><strong>The Operator Log</strong></a>: The full, unfiltered build log of the DALO factory. Read this to understand how the machine works from the inside.
            </li>
        </ol>

        <!-- Mid-page CTA box -->
        <div class="blockquote-box">
            <p>Thanks for stopping by! Subscribe for free to receive new posts and follow the live build journal.</p>
            <div class="flex mt-4 max-w-[400px] mx-auto">
                <input id="email-mid" type="email" placeholder="Type your email..." class="flex-1 px-4 py-2.5 text-[15px] bg-white border border-[#5272cc] border-r-0 rounded-l-[8px] outline-none text-[#363737]" />
                <button id="btn-subscribe-mid" class="bg-[#5272cc] hover:bg-[#3e62c6] text-white font-semibold text-[15px] px-5 py-2.5 rounded-r-[8px] transition-colors whitespace-nowrap">
                    Subscribe
                </button>
            </div>
        </div>

        <hr class="border-[#e6e4de] my-8" />

        <!-- People Section -->
        <h3>People</h3>
        <div class="mt-4">
            <!-- Author Card -->
            <div class="border border-[#e6e4de] rounded-[12px] p-4 max-w-[356px]">
                <div class="flex items-center justify-between mb-3">
                    <div>
                        <div class="font-semibold text-[15px] text-[#111111]">Operator</div>
                        <div class="text-[13px] text-[#757575]">@dalo_fictions</div>
                    </div>
                    <div class="w-12 h-12 rounded-full overflow-hidden border border-[#e6e4de] bg-[#f0eee8] flex items-center justify-center shrink-0">
                        <img src="/images/dalo-logo.svg" alt="Operator" class="w-8 h-8 object-contain" />
                    </div>
                </div>
                <p class="text-[14px] text-[#5d5437] mb-4" style="font-family: 'Spectral', serif; font-size: 14px; line-height: 20px; margin-bottom: 1rem;">
                    Building AI ventures from Chicago. Documenting every win, every failure, in real time.
                </p>
                <div class="flex gap-2 mb-4">
                    <button class="bg-[#5272cc] hover:bg-[#3e62c6] text-white font-semibold text-[13px] px-5 py-2 rounded-[8px] transition-colors">
                        Subscribe
                    </button>
                    <button class="border border-[#e6e4de] text-[#363737] hover:bg-[#f0eee8] font-medium text-[13px] px-5 py-2 rounded-[8px] transition-colors">
                        Message
                    </button>
                </div>
                <div class="border-t border-[#e6e4de] pt-3 flex items-center gap-2">
                    <div class="w-6 h-6 rounded overflow-hidden border border-[#e6e4de]">
                        <img src="/images/dalo-logo.svg" alt="DALO" class="w-full h-full object-cover" />
                    </div>
                    <span class="text-[12px] text-[#757575]">DALO Fictions <span class="font-semibold text-[#363737]">By Operator</span></span>
                </div>
            </div>
        </div>

    </main>

    <!-- Footer -->
    <footer class="mt-20 py-10 bg-[#f0eee8] border-t border-[#e6e4de] flex flex-col items-center justify-center gap-4 text-[13px] text-[#757575]">
        <div>© 2026 DALO Fictions · Privacy · Terms</div>
    </footer>

    <script is:inline>
        function handleSubscribe(inputId) {
            const input = document.getElementById(inputId);
            const email = input ? input.value.trim() : '';
            if (!email) {
                alert('이메일 주소를 입력해 주세요!');
                return;
            }
            alert(`🚀 "${email}" 구독 신청이 완료되었습니다!`);
            if (input) input.value = '';
        }

        document.getElementById('btn-subscribe-top')?.addEventListener('click', () => handleSubscribe('email-top'));
        document.getElementById('btn-subscribe-mid')?.addEventListener('click', () => handleSubscribe('email-mid'));
    </script>
</body>
</html>
