---
import ControlTowerLayout from '../layouts/ControlTowerLayout.astro';
import db from '../data/db.json';
---

<ControlTowerLayout 
	title="AI 오퍼레이터 제어실 | Chicago AI Web Factory"
	description="C:/appdev/ 프로젝트 연동, 이중 버퍼 드래프트 관리, 피드백 루프 및 SNS 다채널 배포 엔진 제어실"
>
	<div class="bg-slate-50 min-h-screen py-10">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<!-- Header -->
			<div class="mb-10 flex flex-col md:flex-row md:items-center md:justify-between border-b border-slate-200 pb-6">
				<div>
					<span class="text-blue-600 font-bold text-sm tracking-wider uppercase">Control Tower Dashboard</span>
					<h1 class="text-3xl font-extrabold text-slate-900 tracking-tight mt-1">AI 오퍼레이터 제어실</h1>
					<p class="text-slate-500 text-sm mt-1">
						C:/appdev/ 하위 프로젝트 파일 동기화, 마케팅 드래프트 큐 및 SNS 배포 자동화 엔진.
					</p>
				</div>
				<div class="mt-4 md:mt-0 flex gap-3">
					<button id="btn-sync-trigger" class="bg-white hover:bg-slate-100 text-slate-700 border border-slate-300 font-semibold px-4 py-2 rounded-lg text-sm transition shadow-sm">
						🔄 로컬 프로젝트 재동기화
					</button>
				</div>
			</div>

			<!-- Dashboard Grid -->
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
				
				<!-- Left Column: Project list & Flash Insight -->
				<div class="space-y-8 lg:col-span-1">
					
					<!-- Projects Panel -->
					<div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
						<h3 class="font-bold text-lg text-slate-900 mb-4 flex items-center gap-2">
							📁 로컬 프로젝트 리스트
						</h3>
						<div class="space-y-3 overflow-y-auto max-h-[300px]" id="project-list-container">
							{db.projects.map(proj => (
								<div class="bg-slate-50 border border-slate-200 rounded-xl p-4 transition hover:border-blue-400">
									<div class="flex justify-between items-start">
										<div>
											<h4 class="font-semibold text-slate-900 text-sm">{proj.name}</h4>
											<p class="text-xs text-slate-500 mt-0.5">{proj.id}</p>
										</div>
										<span class="bg-blue-50 text-blue-600 text-[10px] font-bold px-2 py-0.5 rounded-full border border-blue-100">
											{proj.status === 'in-progress' ? '구축중' : '기획'}
										</span>
									</div>
									<div class="mt-3 flex justify-between items-center text-[11px] text-slate-500">
										<span>📍 C:/appdev/{proj.id}</span>
									</div>
								</div>
							))}
						</div>
					</div>

					<!-- Flash Insight System -->
					<div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
						<h3 class="font-bold text-lg text-slate-900 mb-2 flex items-center gap-2">
							⚡ Flash Insight 입력 (긴급 큐)
						</h3>
						<p class="text-slate-500 text-xs mb-4">
							즉흥적인 메모나 영감을 마케팅 글로 확장해 드래프트 큐 최상단(#1)에 등록합니다.
						</p>
						
						<div class="space-y-4">
							<div>
								<label class="block text-xs font-semibold text-slate-700 mb-1">인사이트 태깅 분류</label>
								<select id="flash-tag-select" class="w-full text-sm border border-slate-200 rounded-lg p-2.5 outline-none focus:border-blue-600">
									<option value="general">🌍 General (독립 에세이/통찰)</option>
									{db.projects.map(proj => (
										<option value={proj.id}>📁 {proj.name}</option>
									))}
								</select>
							</div>

							<div>
								<label class="block text-xs font-semibold text-slate-700 mb-1">메모 및 원시 아이디어</label>
								<textarea id="flash-memo-input" rows="4" class="w-full text-sm border border-slate-200 rounded-lg p-3 outline-none focus:border-blue-600 resize-none" placeholder="여기에 즉각적인 생각이나 핵심 메시지를 입력하세요..."></textarea>
							</div>

							<button id="btn-flash-generate" class="w-full bg-slate-900 hover:bg-black text-white text-sm font-bold py-2.5 rounded-lg transition shadow-sm">
								🚀 긴급 드래프트 생성 (Queue #1)
							</button>
						</div>
					</div>

					<!-- Draft Queue Buffer Panel -->
					<div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
						<h3 class="font-bold text-lg text-slate-900 mb-2 flex items-center gap-2">
							🔄 Review Queue (이중 버퍼)
						</h3>
						<p class="text-slate-500 text-xs mb-4">
							각 프로젝트별로 정확히 2개의 대기 드래프트를 유지 관리합니다.
						</p>
						<div id="draft-queue-container" class="space-y-3">
							<!-- Populated via Javascript -->
						</div>
					</div>

				</div>

				<!-- Right Column: Interactive Admin Workbench -->
				<div class="space-y-8 lg:col-span-2">
					
					<!-- Workbench Workspace -->
					<div class="bg-white rounded-2xl border border-slate-200 p-8 shadow-sm min-h-[600px] flex flex-col gap-6">
						
						<div class="flex justify-between items-center border-b border-slate-100 pb-4">
							<div>
								<h2 id="workbench-title" class="text-xl font-bold text-slate-900">선택된 드래프트 없음</h2>
								<p id="workbench-meta" class="text-xs text-slate-500 mt-1">대기열에서 검토할 드래프트를 클릭해 로드하세요.</p>
							</div>
							<div class="flex gap-2">
								<button id="btn-publish" class="hidden bg-blue-600 hover:bg-blue-700 text-white font-bold px-4 py-2 rounded-lg text-xs transition shadow-sm">
									📢 최종 승인 및 발행
								</button>
								<button id="btn-edit-published" class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold px-4 py-2 rounded-lg text-xs transition">
									📝 발행글 수정 모드
								</button>
							</div>
						</div>

						<!-- Human Readable Preview Workspace -->
						<div id="workbench-preview-container" class="flex-grow border border-slate-100 bg-slate-50/50 rounded-xl p-6 overflow-y-auto max-h-[500px]">
							<div id="workbench-html-output" class="prose max-w-none text-slate-800">
								<!-- Rendered clean HTML showing human-friendly preview with visual tags -->
								<div class="text-center py-20 text-slate-400">
									<span class="text-4xl">💻</span>
									<p class="mt-4 font-semibold text-sm">드래프트를 선택하여 작업대 프리뷰를 시작하세요.</p>
								</div>
							</div>
						</div>

						<!-- Feedback loop -->
						<div id="feedback-panel" class="hidden border-t border-slate-100 pt-6">
							<label class="block text-xs font-semibold text-slate-700 mb-2">🤖 AI 피드백 루프 (드래프트 개선 지시)</label>
							<div class="flex gap-3">
								<input type="text" id="feedback-input" class="flex-grow border border-slate-200 rounded-lg px-4 py-2 text-sm outline-none focus:border-blue-600" placeholder="예: '인간적 고뇌 부분을 더 강조하고, 바람 부는 날 사진촬영 팁을 한 줄 추가해줘...'" />
								<button id="btn-feedback-submit" class="bg-blue-50 text-blue-600 border border-blue-200 font-bold px-4 py-2 rounded-lg text-sm hover:bg-blue-600 hover:text-white transition">
									반영 요청
								</button>
							</div>
							<div class="mt-4 flex gap-2">
								<button id="btn-save-draft" class="bg-slate-900 hover:bg-black text-white text-xs font-bold px-4 py-2 rounded-lg transition">
									💾 드래프트 단순 저장
								</button>
							</div>
						</div>

						<!-- SNS Ready Amplification Output -->
						<div id="sns-output-panel" class="hidden bg-blue-50/50 border border-blue-100 rounded-xl p-6 space-y-4">
							<h4 class="font-bold text-blue-900 text-sm flex items-center gap-2">
								📢 Multi-Channel SNS 스니펫 (발행 시 자동 배포 완료)
							</h4>
							<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
								<div class="bg-white border border-slate-100 rounded-lg p-4">
									<span class="text-xs font-bold text-slate-800 flex items-center gap-1.5 mb-2">
										🔗 LinkedIn
									</span>
									<textarea id="sns-linkedin" class="w-full text-xs text-slate-600 border-none p-0 outline-none resize-none bg-transparent" rows="5"></textarea>
								</div>
								<div class="bg-white border border-slate-100 rounded-lg p-4">
									<span class="text-xs font-bold text-slate-800 flex items-center gap-1.5 mb-2">
										🐦 Twitter/X
									</span>
									<textarea id="sns-twitter" class="w-full text-xs text-slate-600 border-none p-0 outline-none resize-none bg-transparent" rows="5"></textarea>
								</div>
								<div class="bg-white border border-slate-100 rounded-lg p-4">
									<span class="text-xs font-bold text-slate-800 flex items-center gap-1.5 mb-2">
										📸 Instagram
									</span>
									<textarea id="sns-instagram" class="w-full text-xs text-slate-600 border-none p-0 outline-none resize-none bg-transparent" rows="5"></textarea>
								</div>
							</div>
						</div>

					</div>

				</div>

			</div>
		</div>
	</div>
</ControlTowerLayout>

<script>
	// Initialize local client database from Astro server props
	import initialDb from '../data/db.json';

	let db = initialDb;
	if (typeof window !== 'undefined') {
		const saved = localStorage.getItem('control_tower_db');
		if (saved) {
			db = JSON.parse(saved);
		} else {
			localStorage.setItem('control_tower_db', JSON.stringify(initialDb));
		}
	}

	let selectedDraftId: string | null = null;
	let currentEditPostId: string | null = null;

	const draftQueueContainer = document.getElementById('draft-queue-container');
	const workbenchTitle = document.getElementById('workbench-title');
	const workbenchMeta = document.getElementById('workbench-meta');
	const htmlOutput = document.getElementById('workbench-html-output');
	const feedbackPanel = document.getElementById('feedback-panel');
	const publishBtn = document.getElementById('btn-publish');
	const saveDraftBtn = document.getElementById('btn-save-draft');
	const feedbackInput = document.getElementById('feedback-input') as HTMLInputElement;
	const feedbackSubmitBtn = document.getElementById('btn-feedback-submit');
	const snsPanel = document.getElementById('sns-output-panel');
	const linkedinArea = document.getElementById('sns-linkedin') as HTMLTextAreaElement;
	const twitterArea = document.getElementById('sns-twitter') as HTMLTextAreaElement;
	const instagramArea = document.getElementById('sns-instagram') as HTMLTextAreaElement;

	const flashTagSelect = document.getElementById('flash-tag-select') as HTMLSelectElement;
	const flashMemoInput = document.getElementById('flash-memo-input') as HTMLTextAreaElement;
	const flashGenerateBtn = document.getElementById('btn-flash-generate');
	const syncTriggerBtn = document.getElementById('btn-sync-trigger');

	// Helper to parse markdown-like structure to clean HTML preview with visual indicators
	function parseToHumanFriendlyHTML(mdText: string): string {
		let html = mdText
			.replace(/^# (.*$)/gim, '<h1 class="text-2xl font-extrabold text-slate-900 border-b border-slate-100 pb-2 mb-4">$1</h1>')
			.replace(/^## (.*$)/gim, '<h2 class="text-lg font-bold text-slate-800 mt-6 mb-3">$1</h2>')
			.replace(/^### (.*$)/gim, '<h3 class="text-sm font-semibold text-slate-700 mt-4 mb-2">$1</h3>')
			.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
			.replace(/\n\n/g, '</p><p class="text-slate-600 leading-relaxed mb-4">');

		// Wrap in paragraph if not already started
		if (!html.startsWith('<h1') && !html.startsWith('<h2') && !html.startsWith('<h3')) {
			html = '<p class="text-slate-600 leading-relaxed mb-4">' + html + '</p>';
		}

		// Inject Premium Visual Placeholders
		html = html.replace(/\[📷 이미지 추천 포인트: (.*?)\]/gim, `
			<div class="my-6 border border-dashed border-blue-200 bg-blue-50/40 rounded-xl p-5 flex items-start gap-4">
				<span class="text-2xl">📷</span>
				<div>
					<h4 class="text-xs font-bold text-blue-800 uppercase tracking-wide">Premium Visual Guide</h4>
					<p class="text-xs text-blue-700 mt-1">$1</p>
					<span class="inline-flex items-center gap-1.5 mt-2 bg-blue-100 text-blue-800 text-[10px] font-semibold px-2 py-0.5 rounded">이미지 권장 포인트</span>
				</div>
			</div>
		`);

		return html;
	}

	function saveDatabase() {
		localStorage.setItem('control_tower_db', JSON.stringify(db));
		renderDraftQueue();
	}

	function renderDraftQueue() {
		if (!draftQueueContainer) return;
		draftQueueContainer.innerHTML = '';

		if (db.drafts.length === 0) {
			draftQueueContainer.innerHTML = '<p class="text-xs text-slate-400 py-4 text-center">검토 대기 중인 드래프트가 없습니다.</p>';
			return;
		}

		db.drafts.forEach((draft, idx) => {
			const project = db.projects.find(p => p.id === draft.projectId);
			const projName = project ? project.name : 'General';
			const isSelected = draft.id === selectedDraftId;

			const div = document.createElement('div');
			div.className = `p-3.5 border rounded-xl cursor-pointer transition ${isSelected ? 'border-blue-600 bg-blue-50/30' : 'border-slate-200 bg-slate-50 hover:bg-slate-100'}`;
			div.innerHTML = `
				<div class="flex justify-between items-start gap-2">
					<h4 class="text-xs font-bold text-slate-800 truncate flex-grow">${draft.title}</h4>
					<span class="text-[9px] bg-slate-200 text-slate-600 font-semibold px-1.5 py-0.5 rounded">Queue #${idx + 1}</span>
				</div>
				<p class="text-[10px] text-slate-500 mt-1">📁 ${projName}</p>
			`;
			div.addEventListener('click', () => loadDraft(draft.id));
			draftQueueContainer.appendChild(div);
		});
	}

	function loadDraft(id: string) {
		selectedDraftId = id;
		currentEditPostId = null;
		const draft = db.drafts.find(d => d.id === id);
		if (!draft) return;

		const project = db.projects.find(p => p.id === draft.projectId);
		
		workbenchTitle!.textContent = draft.title;
		workbenchMeta!.textContent = `📁 분류: ${project ? project.name : 'General Insight'}`;
		htmlOutput!.innerHTML = parseToHumanFriendlyHTML(draft.content);

		feedbackPanel!.classList.remove('hidden');
		publishBtn!.classList.remove('hidden');
		snsPanel!.classList.add('hidden');

		renderDraftQueue();
	}

	// Feedback refinement loop simulation
	feedbackSubmitBtn?.addEventListener('click', () => {
		const val = feedbackInput.value.trim();
		if (!val || !selectedDraftId) return;

		const draft = db.drafts.find(d => d.id === selectedDraftId);
		if (!draft) return;

		// Simulated Gemini refinement
		htmlOutput!.innerHTML = `<p class="text-blue-600 font-semibold py-10 text-center">🤖 Gemini가 피드백을 반영해 드래프트를 고도화하고 있습니다...</p>`;

		setTimeout(() => {
			draft.content += `\n\n## ✍️ 피드백 반영 사항\n요청하신 사항을 분석하여 스토리텔링 품질을 높였습니다: "${val}"\n\n[📷 이미지 추천 포인트: 피드백 내용에 맞춘 포트폴리오 디테일 촬영 컷 및 인터랙션 코드 스크린샷 추가]`;
			draft.title = `[개선됨] ` + draft.title;
			
			workbenchTitle!.textContent = draft.title;
			htmlOutput!.innerHTML = parseToHumanFriendlyHTML(draft.content);
			feedbackInput.value = '';
			saveDatabase();
		}, 1000);
	});

	saveDraftBtn?.addEventListener('click', () => {
		alert('드래프트 내용이 임시 저장되었습니다!');
	});

	// Publish action: publishes draft, generates 3 SNS snippets, saves to sns_ready, and auto-refills
	publishBtn?.addEventListener('click', () => {
		if (!selectedDraftId) return;
		const draftIndex = db.drafts.findIndex(d => d.id === selectedDraftId);
		if (draftIndex === -1) return;

		const draft = db.drafts[draftIndex];
		const project = db.projects.find(p => p.id === draft.projectId);

		// 1. Move to published posts
		const newPost = {
			id: draft.id,
			projectId: draft.projectId,
			title: draft.title,
			description: `${project ? project.name : 'General'}에 대한 AI 가치 에세이`,
			pubDate: new Date().toISOString(),
			category: "Insight Essay",
			tags: project ? project.tags : ["General", "Insight"],
			content: draft.content,
			likes: 0,
			comments: []
		};
		db.posts.unshift(newPost);

		// 2. Generate SNS channel versions
		const cleanTitle = draft.title.replace('[개선됨] ', '');
		const linkedin = `🔗 [LinkedIn 에세이] ${cleanTitle}\n\n시카고 AI 웹 공장 오퍼레이터가 드리는 가치 에세이입니다.\n${draft.content.substring(0, 100)}...\n\n#Astro #ChicagoTech #AIWebFactory`;
		const twitter = `🐦 [Twitter/X] ${cleanTitle}\n\n현장 로그와 AI 오퍼레이터가 연합한 초고속 웹 빌드.\n${draft.content.substring(0, 80)}...\n#Astro #LocalSEO`;
		const instagram = `📸 [Instagram] ${cleanTitle}\n\n로컬 소상공인의 실시간 비즈니스 일지와 AI 연합 엔진.\n${draft.content.substring(0, 90)}...\n#시카고웹 #시카고테크`;

		linkedinArea.value = linkedin;
		twitterArea.value = twitter;
		instagramArea.value = instagram;

		db.sns_ready.unshift({
			postId: draft.id,
			linkedin,
			twitter,
			instagram
		});

		// 3. Remove from drafts
		db.drafts.splice(draftIndex, 1);

		// 4. Auto-Refill Draft Queue: Keep exactly 2 drafts per project
		const projectDrafts = db.drafts.filter(d => d.projectId === draft.projectId);
		if (projectDrafts.length < 2) {
			const gap = 2 - projectDrafts.length;
			for (let i = 0; i < gap; i++) {
				db.drafts.push({
					id: `draft-${draft.projectId}-${Date.now()}-${i}`,
					projectId: draft.projectId,
					title: `${project ? project.name : 'General'}의 AI 마케팅 에세이 #${Date.now()}`,
					content: `# ${project ? project.name : 'General'} - 신규 오퍼레이터 포스팅\n\n## 1. Why (전략)\n지속 가능한 로컬 SEO 마케팅 구조의 설계.\n\n## 2. Human Struggle (인간적 극복)\n품질과 마케팅 자원 분배의 극복 과정.\n\n[📷 이미지 추천 포인트: 모던 시카고 도심 배경과 개발용 대시보드 화면 연출]\n\n## 3. AI Insight (AI의 통찰)\n현장 작업 기록이 실시간 구글 가시성을 확보하게 돕습니다.`,
					status: "review"
				});
			}
		}

		saveDatabase();

		workbenchTitle!.textContent = "발행 완료!";
		workbenchMeta!.textContent = "발행과 동시에 SNS 스니펫이 sns_ready에 자동 저장되었습니다.";
		htmlOutput!.innerHTML = `
			<div class="text-center py-10">
				<span class="text-4xl">🎉</span>
				<h3 class="font-bold text-slate-800 mt-4">게시글 발행 성공</h3>
				<p class="text-xs text-slate-500 mt-1">블로그 게시판에 실시간 배포되었습니다.</p>
			</div>
		`;
		
		publishBtn!.classList.add('hidden');
		feedbackPanel!.classList.add('hidden');
		snsPanel!.classList.remove('hidden');
	});

	// Flash Insight submission: creates immediately, inserts at index 0 (#1 spot)
	flashGenerateBtn?.addEventListener('click', () => {
		const tag = flashTagSelect.value;
		const memo = flashMemoInput.value.trim();

		if (!memo) {
			alert('메모 내용을 입력해 주세요!');
			return;
		}

		// Simulated immediate draft generation
		const projName = tag === 'general' ? 'General' : db.projects.find(p => p.id === tag)?.name;
		const draftId = `draft-flash-${Date.now()}`;
		const newDraft = {
			id: draftId,
			projectId: tag,
			title: `🚨 [Flash Insight] ${memo.substring(0, 30)}...`,
